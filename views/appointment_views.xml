<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hi_appointment_list" model="ir.ui.view">
        <field name="name">hi.appointment.list</field>
        <field name="model">hi.appointment</field>
        <field name="arch" type="xml">
            <list string="المواعيد / Appointments">
                <field name="patient_id"/>
                <field name="doctor_name"/>
                <field name="appointment_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hi_appointment_form" model="ir.ui.view">
        <field name="name">hi.appointment.form</field>
        <field name="model">hi.appointment</field>
        <field name="arch" type="xml">
            <form string="الموعد / Appointment">
                <header>
                    <button name="action_send_sms_simulation" type="object" string="محاكاة إرسال تذكير / Simulate Reminder" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_name"/>
                        </group>
                        <group>
                            <field name="appointment_date"/>
                            <field name="reminder_one_day_sent"/>
                            <field name="reminder_two_hours_sent"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_hi_appointment" model="ir.actions.act_window">
        <field name="name">المواعيد / Appointments</field>
        <field name="res_model">hi.appointment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
